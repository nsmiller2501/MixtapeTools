## paste following into .claude/settings.json (as-is if no "hooks" exists, otherwise add just the "hooks" sub-snippet to existing block)

{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/local/bin/python3",
            "args": ["${CLAUDE_PROJECT_DIR}/.claude/prereview.py"],
            "timeout": 5,
            "statusMessage": "Running prereview guard"
          }
        ]
      }
    ]
  }
}
